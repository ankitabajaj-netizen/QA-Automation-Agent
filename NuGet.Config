<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Scopes this repo to the public feed only, regardless of machine-wide NuGet sources
       (e.g. private org feeds or local folders that may not exist on every machine). -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
